{
  "uid": "font.registry",
  "version": "1.0.0",
  "domain": "font",
  "description": "uCore font character registry — canonical character mappings, native glyph dimensions, and render classifications for the 2 fonts + 1 block set used across all grid surfaces. Powers the Pixel Editor character library and grid algebra column-width / row-height calculations.",

  "fonts": {
    "pressstart2p": {
      "family": "Press Start 2P",
      "source": "google-fonts",
      "glyphNativeW": 8,
      "glyphNativeH": 8,
      "isMonospace": true,
      "isBitmap": true,
      "fontSizeScale": 1.0,
      "category": "terminal",
      "charRange": "0x21-0x7E",
      "charWidth": 8,
      "charHeight": 8,
      "charCount": 94,
      "displayLabel": "Terminal"
    },
    "mode7gx3": {
      "family": "MODE7GX3",
      "source": "local",
      "path": "/fonts/MODE7GX3.TTF",
      "glyphNativeW": 12,
      "glyphNativeH": 10,
      "isMonospace": true,
      "isBitmap": true,
      "fontSizeScale": 1.3,
      "category": "teletext",
      "charRange": "0x20-0x7E",
      "charWidth": 12,
      "charHeight": 10,
      "charCount": 95,
      "displayLabel": "Teletext"
    }
  },

  "blocks": {
    "g0": {
      "description": "G0 teletext block graphics and mosaic characters",
      "glyphW": 12,
      "glyphH": 10,
      "renderScale": 2,
      "mosaicRange": "0x60-0x7F",
      "defaultChars": "█▄▀▐▌░▒▓│─║═╔╗╚╝╠╣╦╩╬·☼◄►▲▼◆○●⬛",
      "extraChars": "▀▄█▌▐░▒▓▖▗▘▙▚▛▜▝▞▟"
    }
  },

  "classification": {
    "text": {
      "description": "Standard text characters rendered via fillText with font family",
      "pressstart2p": "0x21-0x7E",
      "mode7gx3": "0x20-0x5E"
    },
    "block": {
      "description": "Solid block/drawing characters rendered as filled rectangles or via G0 bitmap pipeline",
      "common": "=-|#*.~Xx+·",
      "mode7gx3_code": "0x2580-0x259F,0x2500-0x257F"
    },
    "mosaic": {
      "description": "2x3 sub-cell mosaic block graphics, algorithmic generation",
      "range": "0x60-0x7F",
      "subGrid": "2x3",
      "bits": 6
    }
  },

  "characterMap": {
    "description": "Explicit per-character dimension overrides for non-uniform glyphs. All characters default to their font's charWidth × charHeight unless listed here.",
    "overrides": {
      " ": { "w": 0, "h": 0 },
      ".": { "w": 4, "h": 2 },
      ":": { "w": 4, "h": 6 },
      ";": { "w": 4, "h": 6 },
      "'": { "w": 3, "h": 4 },
      "i": { "w": 6, "h": 10 },
      "l": { "w": 6, "h": 10 },
      "I": { "w": 8, "h": 10 },
      "|": { "w": 4, "h": 10 },
      "!": { "w": 4, "h": 10 },
      "(": { "w": 6, "h": 10 },
      ")": { "w": 6, "h": 10 },
      "[": { "w": 6, "h": 10 },
      "]": { "w": 6, "h": 10 },
      "f": { "w": 8, "h": 10 },
      "j": { "w": 6, "h": 10 },
      "t": { "w": 8, "h": 10 },
      "r": { "w": 8, "h": 10 },
      ",": { "w": 4, "h": 4 }
    }
  }
}
