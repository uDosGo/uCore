# Hivemind Environment Configuration
# Copy to ~/.config/hivemind/.env and fill in your API keys

# OpenRouter API Key (for cloud model routing)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Roundtable AI (local LLM server)
ROUNDTABLE_BASE_URL=http://localhost:4891/v1

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI Fallback (last resort)
OPENAI_API_KEY=

# Budget Configuration
SESSION_BUDGET_USD=5.0
DAILY_BUDGET_USD=10.0
MONTHLY_BUDGET_USD=50.0
